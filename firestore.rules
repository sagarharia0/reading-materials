rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Content collection: anyone can read, only backend can write
    match /content/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Digests collection: anyone can read, only backend can write
    match /digests/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Highlights: read and write from frontend (personal tool)
    match /highlights/{docId} {
      allow read, write: if true;
    }
    // Learning profile: read from frontend, write from backend only
    match /learningProfile/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
